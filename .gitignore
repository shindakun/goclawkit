# Built example binaries. Anchored paths only, so these never match the cmd/<name>/
# SOURCE directories (a bare "roll" would, since a slash-less pattern matches any
# path component, including a dir).
/roll
/webhook
/irc
/cmd/roll/roll
/cmd/webhook/webhook
/cmd/irc/irc

# Plugin build staging dir (scripts/build-plugin.sh output).
/build/

# Test binaries / coverage
*.test
*.out
coverage.*

# Go build/work files
go.work
go.work.sum

# Editor / OS noise
.DS_Store
*.swp
*~
.idea/
.vscode/
